{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sublime-skills.local/sdd/state-schema.json",
  "title": "SDD State File",
  "description": "Schema for .sublime-skills/state.json (single global file, gitignored). Canonical companion to state-schema.md.",
  "type": "object",
  "required": [
    "started_at",
    "updated_at",
    "current_stage",
    "stages_completed",
    "stages_skipped",
    "tasks"
  ],
  "additionalProperties": false,
  "$comment": "feature_id, short_name, work_type, spec_path are not in the always-required set: preflight (Stage 0) creates the state shell before these are knowable; ss-sdd-writing-specs (Stage 2) writes them. They are required-by-Stage-2 — every skill that reads them runs at Stage 3 or later, so they can assume presence.",
  "properties": {
    "feature_id": {
      "type": "string",
      "pattern": "^[0-9]{3}-[a-z][a-z0-9-]*$",
      "description": "Format: NNN-<short-name>"
    },
    "short_name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Kebab-case short name"
    },
    "work_type": {
      "type": "string",
      "enum": ["feature", "fix"],
      "description": "Captured at Stage 1 by ss-sdd-discovering-requirements. Used by ss-sdd-choosing-feature-branch (Stage 7) to derive the suggested branch prefix (feat/ vs fix/)."
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "spec_path": {
      "type": "string",
      "minLength": 1
    },
    "plan_path": {
      "type": ["string", "null"],
      "description": "Set by ss-sdd-writing-plans at Stage 6"
    },
    "branch_name": {
      "type": "string",
      "minLength": 1,
      "description": "The branch the user committed to at Stage 7. Set by ss-sdd-choosing-feature-branch; read by ss-sdd-finishing (Stage 11) to know which branch to merge into main and delete."
    },
    "current_stage": {
      "type": "string",
      "enum": [
        "preflight",
        "discovering",
        "spec_writing",
        "spec_auto_review",
        "adr_maintenance",
        "spec_approval",
        "plan_writing",
        "choosing_branch",
        "implementing",
        "testing",
        "memory_file",
        "finishing"
      ]
    },
    "stages_completed": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "preflight",
          "discovering",
          "spec_written",
          "spec_auto_reviewed",
          "adrs_maintained",
          "spec_approved",
          "plan_written",
          "branch_chosen",
          "implementation_complete",
          "testing_complete",
          "memory_file_maintained",
          "finished"
        ]
      }
    },
    "stages_skipped": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "testing",
          "memory_file"
        ]
      }
    },
    "tasks": {
      "type": "object",
      "patternProperties": {
        "^T[0-9]{3,}$": {
          "type": "string",
          "enum": ["pending", "in_progress", "completed"]
        }
      },
      "additionalProperties": false
    },
    "adr_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "status", "path"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^ADR-[0-9]{4}$"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["Proposed", "Accepted", "Deprecated"],
            "description": "Note: 'Superseded by ADR-NNNN' status is tracked in the ADR file itself, not here. This field reflects the status at time of write."
          },
          "path": {
            "type": "string"
          }
        }
      }
    },
    "test_status": {
      "type": ["string", "null"],
      "enum": [
        null,
        "passed",
        "passed_after_fixes",
        "skipped_mcp_unavailable",
        "skipped_user_choice",
        "failed_escalated"
      ]
    },
    "fix_iterations": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3
    },
    "final_review_completed": {
      "type": "boolean"
    },
    "memory_file_updated": {
      "type": "boolean"
    },
    "memory_file_path": {
      "type": ["string", "null"]
    },
    "reviewer_pushbacks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stage", "finding", "reason"],
        "additionalProperties": false,
        "properties": {
          "stage": {
            "type": "string"
          },
          "finding": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "spec_auto_review_iterations": {
      "type": "integer",
      "minimum": 0,
      "maximum": 2
    }
  }
}
